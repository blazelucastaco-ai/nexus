write_file(path='~/nexus-workspace/scraper.py', content='import requests\nimport json\n\ndef fetch_and_print_json(url):\n    """\n    Fetches JSON data from a given URL and prints it.\n    """\n    try:\n        response = requests.get(url)\n        response.raise_for_status()  # Raise an exception for HTTP errors\n\n        json_data = response.json()\n        print(json.dumps(json_data, indent=4)) # Pretty print the JSON\n    except requests.exceptions.RequestException as e:\n        print(f"Error fetching data: {e}")\n    except json.JSONDecodeError as e:\n        print(f"Error decoding JSON: {e}")\n\nif __name__ == "__main__":\n    target_url = "https://httpbin.org/json"\n    fetch_and_print_json(target_url)}')