# NEXUS Hub — copy to .env and fill in.

# Where the hub listens.
PORT=8787
HOST=127.0.0.1

# SQLite database file. Relative to the hub working dir.
DB_PATH=./data/hub.db

# JWT signing secret. MUST be ≥ 32 random bytes, base64 or hex. Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('base64'))"
# Change this in production and NEVER commit it.
JWT_SECRET=change-me-to-a-real-secret-before-running-in-prod

# Access token lifetime (short — these are in memory on the client).
ACCESS_TOKEN_TTL_SECONDS=900        # 15 min

# Refresh token lifetime (longer — httpOnly cookie or Keychain-stored).
REFRESH_TOKEN_TTL_SECONDS=2592000   # 30 days

# scrypt cost params are hardcoded (N=2^15, r=8, p=1) following OWASP 2024.
# Raise inside src/auth.ts if you want slower logins for extra brute-force cost.

# CORS — comma-separated origins allowed to hit the hub. Include the installer
# app scheme (file://) and any web UI you'll build later.
CORS_ORIGINS=http://localhost:5173,file://

# Rate-limit: max auth attempts per 15-minute window per IP.
AUTH_RATE_LIMIT=10

# Set to 1 in production. Forces cookies to Secure + SameSite=Strict.
PRODUCTION=0

# Per-user rate limit for authenticated routes (per-minute). Protects
# /posts, /gossip, /soul, /friends from a compromised-token spam attack.
AUTHED_RATE_LIMIT=300

# ── Optional error monitoring ─────────────────────────────────────────
# Set to a Sentry DSN to stream runtime errors to your Sentry project.
# Leave unset to disable (no-op, no network calls, no extra deps loaded).
# Sign up at sentry.io (free tier 5k events/month). Paste the DSN here.
# SENTRY_DSN=https://<id>@<host>/<project>

# ── Optional tags that appear alongside errors ────────────────────────
# Helps distinguish staging from prod in a shared Sentry project.
# HUB_ENV=prod
