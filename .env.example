# ─── NEXUS AI Configuration ───────────────────────────────
# Copy this file to .env and fill in your values

# Telegram Bot (REQUIRED)
NEXUS_TELEGRAM_TOKEN=your_telegram_bot_token
NEXUS_CHAT_ID=your_telegram_chat_id

# AI Providers (at least one required)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# AI Settings
NEXUS_AI_PROVIDER=anthropic
# Tiered model routing:
# - opusModel: heavy reasoning (task planning, CoWork, Ultra review)
# - model:     primary workhorse (chat, task execution, vision, self-eval)
# - fastModel: lightweight classification (synthesis, reasoning trace, summaries)
NEXUS_AI_MODEL=claude-sonnet-4-6
NEXUS_AI_OPUS_MODEL=claude-opus-4-7
NEXUS_AI_FAST_MODEL=claude-haiku-4-5-20251001
NEXUS_AI_FALLBACK_MODEL=claude-haiku-4-5-20251001

# Logging
LOG_LEVEL=info

# Ollama (optional, for local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
