{
  "name": "nexus-ai",
  "version": "0.1.0",
  "description": "NEXUS — A personal AI that lives on your Mac, communicates via Telegram",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nexus": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup && cp dist/index.cjs ~/.nexus/app/index.cjs",
    "deploy": "pnpm build && launchctl kickstart -k gui/$(id -u)/com.nexus.ai",
    "restart": "launchctl kickstart -k gui/$(id -u)/com.nexus.ai",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx scripts/setup.ts",
    "dev:chat": "tsx scripts/dev-chat.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^8.3.2",
    "@types/cheerio": "^0.22.35",
    "@types/pdf-parse": "^1.1.5",
    "better-sqlite3": "^11.7.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cheerio": "^1.2.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "gradient-string": "^3.0.0",
    "grammy": "^1.35.0",
    "inquirer": "^12.4.0",
    "nanoid": "^5.1.2",
    "openai": "^4.85.0",
    "ora": "^8.2.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@biomejs/biome"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.13.0",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
